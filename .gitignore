# Everything excluded by default, then whitelist
*

# Whitelist: core project files
!.gitignore
!.nojekyll
!README.md
!SKILL.md
!SKILL.md.template
!config.example.json
!requirements.txt
!wrangler.toml
!CLAUDE.md
!workflow.png
!before_after.png

# Pipeline scripts
!pipeline/
!pipeline/*.py
!pipeline/lib/
!pipeline/lib/*.py
!pipeline/api/
!pipeline/api/*.py
!pipeline/_archive/
!pipeline/_archive/*.py

# Cloudflare Worker function (handles /api/audio-email + serves static assets).
# Deployed by `wrangler deploy` alongside docs/.
!worker/
!worker/*.js

# Git hooks installer + helper scripts
!scripts/
!scripts/*

# CI workflows
!.github/
!.github/workflows/
!.github/workflows/*.yml

# TODO progress doc
!paper-curation-todo.md

# Double-click launchers (serve docs/ + open topic site on localhost)
!open.command
!open_*.command

# Documentation (whitelist specific service files below)
!docs/
!docs/index.html
!docs/setup-guide.md
!docs/operations.md

# docs/ is the Cloudflare Workers deploy source, NOT a GitHub-served asset.
# Only the landing redirect, setup guide, and wrangler .assetsignore are
# tracked. Full content (docs/papers/, docs/{humanoid,physical-ai}/, etc.)
# is uploaded to Cloudflare via `wrangler deploy`; ai4s/scisci are local-only
# (excluded from Cloudflare via docs/.assetsignore).
!docs/.assetsignore

# Localhost-only API key cache (auto-generated by build_topic_index.py for
# local dev; never deployed). Keeps operator from re-entering Anthropic +
# OpenAI keys every time they open http://localhost/*/ai4s/
docs/_local_keys.json

# Localhost-only Zotero itemKey lookup (auto-generated by
# build_topic_index.py). Maps each paper slug to its Zotero item key so
# the Deep Research References list can render a one-click 'Open PDF'
# button via the zotero://open-pdf/library/items/<KEY> protocol handler.
# Never deployed.
docs/_zotero_keys.json

# Exclude local config and temp files
config.json
__pycache__/
pipeline/__pycache__/
pipeline/lib/__pycache__/
pipeline/_update_force_checkpoint.json
pipeline/_update_force.log
pipeline/_img_timelines/
pipeline/_img_workflows/*
!pipeline/_img_workflows/workflow.png
_regen_*.py

# Exclude Claude Code / OMC runtime files that may land under docs/
docs/**/.claude/
docs/**/.omc/

# Exclude Obsidian vault files
docs/.obsidian/
docs/**/.obsidian/

# Exclude internal planning / spec drafts
docs/superpowers/

docs/ai4s/
docs/scisci/

# Auto-generated by prepare_deploy.py
papers/*/text.md
