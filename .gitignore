# Everything excluded by default, then whitelist
*

# Whitelist: core project files
!.gitignore
!.nojekyll
!README.md
!SKILL.md
!SKILL.md.template
!config.example.json
!wrangler.toml
!CLAUDE.md
!workflow.png

# Pipeline scripts
!pipeline/
!pipeline/*.py
!pipeline/lib/
!pipeline/lib/*.py

# Documentation (whitelist specific service files below)
!docs/
!docs/index.html
!docs/setup-guide.md

# GitHub Pages deployment (under docs/)
!docs/papers/
!docs/papers/*/
!docs/papers/*/index.html
!docs/papers/*/review.md
!docs/papers/*/figures/
!docs/papers/*/figures/*.webp

!docs/*/
!docs/*/network.html
!docs/*/*.png
!docs/*/*.webp

# Exclude pipeline-generated data (created by running scripts)
docs/*/_*.json
docs/*/_*.txt
docs/*/*.json
docs/papers/*/text.md
docs/papers/*/originality.md

# Deep Research search index — explicitly whitelisted for deployment
!docs/*/_search_index.json

# Personal notes (Obsidian-editable, always local, never deployed).
# Paper-level notes live alongside each review.md; general notes live
# in docs/notes/{topic}/. Both are indexed into _search_index.json at
# build time so Deep Research can cite them alongside paper reviews.
docs/papers/*/notes.md
docs/notes/

# Localhost-only API key cache (auto-generated by build_topic_index.py for
# local dev; never deployed). Keeps operator from re-entering Anthropic +
# OpenAI keys every time they open http://localhost/*/ai4s/
docs/_local_keys.json

# Localhost-only Zotero itemKey lookup (auto-generated by
# build_topic_index.py). Maps each paper slug to its Zotero item key so
# the Deep Research References list can render a one-click 'Open PDF'
# button via the zotero://open-pdf/library/items/<KEY> protocol handler.
# Never deployed.
docs/_zotero_keys.json

# Exclude local config and temp files
config.json
__pycache__/
pipeline/__pycache__/
pipeline/lib/__pycache__/
pipeline/_update_force_checkpoint.json
pipeline/_update_force.log
pipeline/_img_timelines/
pipeline/_img_workflows/*
!pipeline/_img_workflows/workflow.png
_regen_*.py

# Exclude Claude Code / OMC runtime files that may land under docs/
docs/**/.claude/
docs/**/.omc/

# Exclude Obsidian vault files
docs/.obsidian/
docs/**/.obsidian/

# Exclude internal planning / spec drafts
docs/superpowers/

docs/ai4s/
docs/scisci/
