# Paper Curation — local credentials
#
# 1. cp .env.example .env
# 2. Open .env and paste the two required API keys.
# 3. npx . setup --auth oauth
#
# Claude uses the saved `claude auth login` subscription session, so no
# ANTHROPIC_API_KEY is needed. Setup discovers Zotero collections through the
# API and creates a local PDF cache automatically.

# Required: Zotero library and attachment access
ZOTERO_API_KEY=

# Required: figure validation, search embeddings, and TTS
# GOOGLE_API_KEY is accepted as an equivalent variable name.
GEMINI_API_KEY=