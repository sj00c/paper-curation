# Paper Curation — local credentials
#
# 1. cp .env.example .env
# 2. Open .env and paste the required API keys.
# 3. node ./bin/paper-curation.mjs setup --fresh-config
#
# Setup reads credentials from .env/process env first and writes a local
# secret-free config. Claude can use `CLAUDE_CODE_OAUTH_TOKEN`,
# `ANTHROPIC_API_KEY`, or an existing `claude auth login` session. Setup
# discovers Zotero collections through the API and creates a local PDF cache.

# Required: Zotero library and attachment access
ZOTERO_API_KEY=

# Required: figure validation, search embeddings, and TTS
# GOOGLE_API_KEY is accepted as an equivalent variable name.
GEMINI_API_KEY=